5 + 2 = 7 // sinal {+} serve para somar
5 - 2 = 3 // sinal {-} serve para subitrair 
5 * 2 = 10 // sinal {*} serve para multiplicar
5 / 2 = 2.5 // sinal {/} serve para dividir
5 % 2 = 1 // sinal {%} serve para pegar o resto da divisao
5 ** 2 = 25 // sinal {**} serve para elevar o numero para um expoente

